       FractionBox["1", "3"]}]}], ",", 
     RowBox[{"H", "\[Equal]", 
      RowBox[{"0", "+", 
       FractionBox["1", "8"]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"y", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"StreamPlot", "[", 
  RowBox[{
   RowBox[{"{", 
