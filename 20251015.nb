Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"P", "=", 
   RowBox[{"y", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["x", "2"], "-", 
      RowBox[{"a", " ", 
       SuperscriptBox["y", "2"]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Q", "=", 
   RowBox[{
    RowBox[{"-", "x"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"c", " ", 
       SuperscriptBox["x", "2"]}], "+", 
      SuperscriptBox["y", "2"]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"H", "=", 
   RowBox[{
    FractionBox[
     SuperscriptBox["y", "2"], "2"], "-", 
    FractionBox[
     RowBox[{"a", " ", 
      SuperscriptBox["y", "4"]}], "4"], "+", 
    FractionBox[
     SuperscriptBox["x", "2"], "2"], "-", 
    FractionBox[
     RowBox[{"c", " ", 
      SuperscriptBox["x", "4"]}], "4"], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["x", "2"], 
      SuperscriptBox["y", "2"]}], "2"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", "4"}], ";", 
  RowBox[{"c", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"H", "\[Equal]", "0"}], ",", 
